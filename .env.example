DATABASE_URI=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# The app also accepts DATABASE_URL, POSTGRES_URL, POSTGRES_PRISMA_URL, or POSTGRES_URL_NON_POOLING.

# Required for signing admin sessions in production.
ADMIN_SESSION_SECRET=change_this_to_a_long_random_secret

# Used only to create the first database admin user when admin_users is empty.
ADMIN_LOGIN=admin
ADMIN_NAME=Administrator
ADMIN_PASSWORD=change_this_password

NEXT_PUBLIC_SERVER_URL=http://localhost:3000